.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 60px;
  background: white;
  border-top: 1px solid #f0f0f0;
  display: flex;
  justify-content: space-around;
  align-items: center;
  z-index: 20;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4px;
  flex: 1;
  height: 100%;
  background: transparent;
  color: #999;
  font-size: 10px;
}

.nav-item .nav-icon {
  font-size: 24px;
}

.nav-item.active {
  color: #2ECC71;
}

.nav-item.active .nav-icon {
  font-size: 28px;
}

.nav-label {
  font-size: 10px;
  font-weight: 500;
}