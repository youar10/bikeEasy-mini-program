page {
  margin: 0;
  padding: 0;
  font-family: 'Noto Sans TC', -apple-system, BlinkMacSystemFont, sans-serif;
  background: #f8fcf9;
  color: #333;
}

view, text, button, input, textarea {
  box-sizing: border-box;
}

button {
  padding: 0;
  border: none;
  background: transparent;
  color: inherit;
  margin: 0;
}

button::after {
  border: none;
}