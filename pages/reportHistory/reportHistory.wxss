.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f8fcf9;
}

.header {
  display: flex;
  align-items: center;
  padding: 16px;
  background: white;
  border-bottom: 1px solid #eee;
}

.back-btn {
  background: transparent;
  color: #333;
  font-size: 20px;
  padding: 0;
  margin-right: 16px;
}

.title {
  flex: 1;
  font-size: 18px;
  font-weight: bold;
  color: #333;
}

.filter-bar {
  background: white;
  padding: 12px;
  display: flex;
  gap: 8px;
  border-bottom: 1px solid #eee;
}

.filter-btn {
  padding: 8px 16px;
  border: 1px solid #ddd;
  background: white;
  border-radius: 20px;
  font-size: 12px;
  color: #666;
  font-weight: 500;
}

.filter-btn.active {
  background: #2ECC71;
  color: white;
  border-color: #2ECC71;
}

.reports-list {
  flex: 1;
  padding: 12px;
}

.report-card {
  background: white;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}

.report-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.report-number {
  font-size: 14px;
  font-weight: bold;
  color: #333;
}

.report-status {
  font-size: 12px;
  font-weight: bold;
  padding: 4px 12px;
  border-radius: 12px;
}

.report-status.status-processing {
  background: #fff3cd;
  color: #FF9800;
}

.report-status.status-completed {
  background: #d4edda;
  color: #2ECC71;
}

.report-type {
  font-size: 14px;
  color: #333;
  margin-bottom: 8px;
  font-weight: 500;
}

.report-location {
  font-size: 12px;
  color: #666;
  margin-bottom: 6px;
}

.report-date {
  font-size: 12px;
  color: #999;
  margin-bottom: 8px;
}

.report-description {
  font-size: 12px;
  color: #666;
  line-height: 1.5;
  margin-bottom: 12px;
  padding: 8px;
  background: #f9f9f9;
  border-radius: 6px;
}

.detail-btn {
  width: 100%;
  padding: 10px;
  background: #f0f0f0;
  color: #666;
  border-radius: 8px;
  font-size: 12px;
  font-weight: bold;
  text-align: center;
}

.empty-state {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 20px;
}

.empty-icon {
  font-size: 64px;
  margin-bottom: 16px;
  opacity: 0.5;
}

.empty-text {
  font-size: 16px;
  color: #333;
}