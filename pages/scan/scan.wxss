.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f8fcf9;
}

.header {
  display: flex;
  align-items: center;
  padding: 16px;
  background: white;
  border-bottom: 1px solid #eee;
}

.back-btn {
  background: transparent;
  color: #333;
  font-size: 20px;
  padding: 0;
  margin-right: 16px;
}

.header-title {
  flex: 1;
  font-size: 16px;
  font-weight: bold;
  color: #333;
}

.content {
  flex: 1;
  overflow-y: auto;
  padding-bottom: 100px;
}

.form {
  padding: 16px;
}

.form-group {
  margin-bottom: 20px;
}

.form-label {
  display: block;
  font-size: 14px;
  font-weight: bold;
  margin-bottom: 8px;
  color: #333;
}

.form-input {
  width: 100%;
  padding: 12px;
  border: 1px solid #ddd;
  border-radius: 8px;
  box-sizing: border-box;
  font-size: 14px;
}

.upload-box {
  width: 100%;
  height: 160px;
  border: 2px dashed #ddd;
  border-radius: 8px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #f9f9f9;
  cursor: pointer;
}

.upload-icon {
  font-size: 48px;
  margin-bottom: 8px;
}

.upload-text {
  font-size: 14px;
  color: #333;
  font-weight: bold;
  margin-bottom: 4px;
}

.upload-hint {
  font-size: 12px;
  color: #999;
}

.picker-value {
  padding: 12px;
  border: 1px solid #ddd;
  border-radius: 8px;
  background: white;
  font-size: 14px;
  color: #333;
}

.submit-btn {
  width: 100%;
  padding: 14px;
  background: #2ECC71;
  color: white;
  border-radius: 8px;
  font-size: 16px;
  font-weight: bold;
  margin-top: 20px;
}