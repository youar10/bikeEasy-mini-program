.container {
  height: 100vh;
  background: #f8fcf9;
}

.content {
  padding-bottom: 60px;
}

.user-card {
  background: linear-gradient(to bottom, #2ECC71, #27ae60);
  color: white;
  padding: 32px 16px;
  display: flex;
  align-items: center;
  gap: 16px;
}

.user-avatar {
  width: 80px;
  height: 80px;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40px;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 20px;
  font-weight: bold;
  margin-bottom: 4px;
}

.user-phone {
  font-size: 12px;
  opacity: 0.9;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
  padding: 12px;
  background: white;
  margin: 12px;
  border-radius: 12px;
}

.stat-item {
  text-align: center;
  padding: 12px;
}

.stat-value {
  display: block;
  font-size: 20px;
  font-weight: bold;
  color: #2ECC71;
  margin-bottom: 4px;
}

.stat-label {
  display: block;
  font-size: 11px;
  color: #999;
}

.eco-card {
  background: white;
  margin: 0 12px 12px;
  padding: 16px;
  border-radius: 12px;
}

.eco-title {
  display: block;
  font-size: 16px;
  font-weight: bold;
  color: #333;
  margin-bottom: 12px;
}

.eco-info {
  display: flex;
  justify-content: space-around;
}

.eco-item {
  text-align: center;
}

.eco-label {
  display: block;
  font-size: 12px;
  color: #999;
  margin-bottom: 4px;
}

.eco-value {
  display: block;
  font-size: 16px;
  font-weight: bold;
  color: #2ECC71;
}

.menu-list {
  background: white;
  margin: 12px;
  border-radius: 12px;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 16px;
  border-bottom: 1px solid #f0f0f0;
  background: white;
  text-align: left;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 20px;
  margin-right: 12px;
}

.menu-label {
  flex: 1;
  font-size: 14px;
  color: #333;
  font-weight: 500;
}

.menu-arrow {
  color: #ccc;
  font-size: 18px;
}

.logout-btn {
  margin: 20px 12px;
  padding: 14px;
  background: #f0f0f0;
  color: #E74C3C;
  border-radius: 8px;
  font-size: 16px;
  font-weight: bold;
  text-align: center;
  width: calc(100% - 24px);
  box-sizing: border-box;
}