.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f8fcf9;
}

.header {
  display: flex;
  align-items: center;
  padding: 16px;
  background: white;
  border-bottom: 1px solid #eee;
}

.back-btn {
  background: transparent;
  color: #333;
  font-size: 20px;
  padding: 0;
  margin-right: 16px;
}

.title {
  flex: 1;
  font-size: 18px;
  font-weight: bold;
  color: #333;
}

.locations-list {
  flex: 1;
  padding: 12px;
}

.location-card {
  background: white;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.location-main {
  flex: 1;
}

.location-type {
  font-size: 12px;
  color: #2ECC71;
  font-weight: bold;
  margin-bottom: 4px;
}

.location-name {
  display: block;
  font-size: 16px;
  font-weight: bold;
  color: #333;
  margin-bottom: 4px;
}

.location-address {
  display: block;
  font-size: 12px;
  color: #999;
}

.location-actions {
  display: flex;
  gap: 8px;
  margin-left: 12px;
}

.action-btn {
  width: 36px;
  height: 36px;
  border-radius: 6px;
  font-size: 16px;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: white;
  border: 1px solid #ddd;
}

.action-btn.navigate {
  background: #2ECC71;
  color: white;
  border-color: #2ECC71;
}

.action-btn.edit {
  background: #f0f0f0;
  color: #666;
}

.action-btn.delete {
  background: #ffe8e8;
  color: #E74C3C;
}

.empty-state {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 20px;
}

.empty-icon {
  font-size: 64px;
  margin-bottom: 16px;
  opacity: 0.5;
}

.empty-text {
  font-size: 16px;
  color: #333;
  font-weight: bold;
  margin-bottom: 8px;
}

.empty-hint {
  font-size: 12px;
  color: #999;
}