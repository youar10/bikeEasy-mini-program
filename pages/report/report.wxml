<view class="container">
  <view class="header">
    <button class="back-btn" bindtap="goBack">←</button>
    <text class="header-title">举报服务</text>
  </view>

  <scroll-view scroll-y class="content">
    <view class="form">
      <view class="form-group">
        <text class="form-label">上传照片</text>
        <text class="form-help">请拍摄违规停泊或损坏的单车照片</text>
        <view class="upload-area" bindtap="uploadPhoto">
          <text class="upload-icon">📸</text>
          <text class="upload-text">点击上传</text>
          <text class="upload-hint">支持 JPG, PNG 格式</text>
        </view>
      </view>

      <view class="form-group">
        <label class="form-label">举报类型</label>
        <picker bindchange="onTypeChange" value="{{typeIndex}}" 
                range="{{typeOptions}}">
          <view class="picker-value">{{typeOptions[typeIndex]}}</view>
        </picker>
      </view>

      <view class="form-group">
        <label class="form-label">详细位置描述</label>
        <textarea placeholder="请输入具体地点、街道名称或附近地标..." 
                  class="form-textarea" bindinput="onLocationChange"></textarea>
      </view>

      <view class="form-group">
        <label class="form-label">单车编号 (选填)</label>
        <input type="text" placeholder="例如：123456" 
               class="form-input" bindinput="onBikeIdChange"/>
      </view>

      <button class="submit-btn" bindtap="submitReport">提交举报</button>
    </view>
  </scroll-view>
</view>