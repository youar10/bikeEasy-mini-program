.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f8fcf9;
}

.header {
  background: white;
  padding: 16px;
  border-bottom: 1px solid #eee;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.title {
  font-size: 18px;
  font-weight: bold;
  color: #333;
}

.add-btn {
  background: #2ECC71;
  color: white;
  padding: 8px 12px;
  border-radius: 6px;
  font-size: 12px;
  font-weight: bold;
}

.bikes-list {
  flex: 1;
  padding: 12px;
}

.bike-card {
  background: white;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  display: flex;
  gap: 12px;
}

.bike-image {
  width: 80px;
  height: 80px;
  background: #f0f0f0;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40px;
  flex-shrink: 0;
}

.bike-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.bike-brand {
  font-size: 16px;
  font-weight: bold;
  color: #333;
  margin-bottom: 4px;
}

.bike-serial {
  font-size: 12px;
  color: #999;
  margin-bottom: 2px;
}

.bike-color {
  font-size: 12px;
  color: #999;
  margin-bottom: 4px;
}

.bike-status {
  font-size: 12px;
  font-weight: bold;
}

.bike-status.status-good {
  color: #2ECC71;
}

.bike-status.status-warning {
  color: #E74C3C;
}

.bike-actions {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.action-btn {
  padding: 6px 8px;
  font-size: 11px;
  border-radius: 6px;
  font-weight: bold;
  border: none;
  white-space: nowrap;
}

.action-btn.view-qr {
  background: #2ECC71;
  color: white;
}

.action-btn.edit {
  background: #f0f0f0;
  color: #666;
}

.action-btn.delete {
  background: #ffe8e8;
  color: #E74C3C;
}

.empty-state {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 20px;
}

.empty-icon {
  font-size: 64px;
  margin-bottom: 16px;
  opacity: 0.5;
}

.empty-text {
  font-size: 16px;
  color: #333;
  font-weight: bold;
  margin-bottom: 8px;
}

.empty-hint {
  font-size: 12px;
  color: #999;
  margin-bottom: 20px;
}

.empty-btn {
  padding: 12px 24px;
  background: #2ECC71;
  color: white;
  border-radius: 8px;
  font-weight: bold;
}