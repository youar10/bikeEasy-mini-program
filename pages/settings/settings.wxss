.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f8fcf9;
}

.header {
  display: flex;
  align-items: center;
  padding: 16px;
  background: white;
  border-bottom: 1px solid #eee;
}

.back-btn {
  background: transparent;
  color: #333;
  font-size: 20px;
  padding: 0;
  margin-right: 16px;
}

.title {
  flex: 1;
  font-size: 18px;
  font-weight: bold;
  color: #333;
}

.content {
  flex: 1;
  padding-bottom: 20px;
}

.settings-section {
  background: white;
  margin: 12px 0;
  padding: 0 16px;
}

.section-title {
  display: block;
  font-size: 12px;
  color: #999;
  text-transform: uppercase;
  font-weight: bold;
  padding: 16px 0 8px;
  letter-spacing: 0.5px;
}

.settings-group {
  border-top: 1px solid #f0f0f0;
}

.settings-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 0;
  border-bottom: 1px solid #f0f0f0;
}

.settings-item:last-child {
  border-bottom: none;
}

.settings-item-btn {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 0;
  border-bottom: 1px solid #f0f0f0;
  background: transparent;
  text-align: left;
}

.settings-item-btn:last-child {
  border-bottom: none;
}

.settings-toggle {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 0;
  border-bottom: 1px solid #f0f0f0;
}

.settings-toggle:last-child {
  border-bottom: none;
}

.item-label {
  font-size: 14px;
  color: #333;
  font-weight: 500;
}

.item-value {
  font-size: 12px;
  color: #999;
}

.item-arrow {
  color: #ccc;
  font-size: 18px;
  margin-left: 8px;
}

switch {
  transform: scale(0.8);
  transform-origin: right center;
}