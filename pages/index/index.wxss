.container {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f8fcf9;
}

.search-bar {
  background: white;
  padding: 12px 16px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}

.search-inputs {
  background: white;
  border-radius: 8px;
  padding: 8px;
}

.search-item {
  display: flex;
  align-items: center;
  padding: 8px 12px;
  border-bottom: 1px solid #f0f0f0;
}

.search-item:last-child {
  border-bottom: none;
}

.search-item input {
  flex: 1;
  border: none;
  margin-left: 8px;
  font-size: 14px;
}

.location-card {
  position: absolute;
  bottom: 60px;
  left: 12px;
  right: 12px;
  background: white;
  border-radius: 16px;
  padding: 16px;
  box-shadow: 0 4px 16px rgba(0,0,0,0.1);
}

.card-title {
  font-size: 16px;
  font-weight: bold;
  margin-bottom: 8px;
}

.card-info {
  font-size: 12px;
  color: #999;
  margin-bottom: 12px;
}

.card-available {
  font-size: 14px;
  color: #333;
  margin-bottom: 12px;
}

.card-available .num {
  color: #2ECC71;
  font-weight: bold;
}

.card-actions {
  display: flex;
  gap: 8px;
}

.btn-primary {
  flex: 1;
  background: #2ECC71;
  color: white;
  padding: 12px;
  border-radius: 8px;
  font-weight: bold;
}

.btn-secondary {
  width: 50px;
  background: #f0f0f0;
  color: #666;
  padding: 12px;
  border-radius: 8px;
}