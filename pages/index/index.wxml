<view class="container">
  <view class="search-bar">
    <view class="search-inputs">
      <view class="search-item">
        <text>●</text>
        <input 
          type="text" 
          placeholder="您的位置"
          value="{{startLocation}}"
          bindinput="onStartChange"
        />
      </view>
      <view class="search-item">
        <text>📍</text>
        <input 
          type="text" 
          placeholder="输入目的地"
          value="{{endLocation}}"
          bindinput="onEndChange"
        />
      </view>
    </view>
  </view>

  <map 
    id="map"
    style="width: 100%; height: 450px;"
    latitude="{{latitude}}"
    longitude="{{longitude}}"
    scale="{{scale}}"
    markers="{{markers}}"
  ></map>

  <view class="location-card" wx:if="{{selectedLocation}}">
    <view class="card-title">{{selectedLocation.name}}</view>
    <view class="card-info">
      <text class="info-text">距离 {{selectedLocation.distance}} • 步行约 {{selectedLocation.walkTime}}</text>
    </view>
    <view class="card-available">
      <text>剩余泊位: <text class="num">{{selectedLocation.available}}</text> / {{selectedLocation.total}}</text>
    </view>
    <view class="card-actions">
      <button class="btn-primary" bindtap="navigateTo">导航至此</button>
      <button class="btn-secondary" bindtap="goToReport">举报</button>
    </view>
  </view>
</view>