<view class="container">
  <view class="header">
    <text class="title">单车易</text>
    <text class="subtitle">您的环保单车伙伴</text>
  </view>

  <view class="form">
    <view class="form-group">
      <label>电话号码</label>
      <input 
        type="tel" 
        placeholder="请输入您的电话号码"
        bindinput="onPhoneChange"
        value="{{phone}}"
      />
    </view>

    <view class="form-group">
      <label>验证码</label>
      <view class="input-with-btn">
        <input 
          type="text"
          placeholder="6位数验证码"
          bindinput="onCodeChange"
          value="{{code}}"
        />
        <button class="send-code-btn" bindtap="sendCode">获取验证码</button>
      </view>
    </view>

    <button class="login-btn" bindtap="login">登入</button>
  </view>

  <view class="divider">或其他方式登入</view>

  <view class="social-buttons">
    <button class="social-btn whatsapp">💬 使用 WhatsApp 登入</button>
    <button class="social-btn apple">🍎 使用 Apple ID 登入</button>
  </view>

  <view class="footer">
    <text class="footer-link">服务条款</text>
    <text class="footer-link">隐私政策</text>
  </view>
</view>