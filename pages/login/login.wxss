.container {
  min-height: 100vh;
  background: white;
  display: flex;
  flex-direction: column;
  padding: 32px 24px 24px;
}

.header {
  text-align: center;
  margin-bottom: 40px;
}

.title {
  display: block;
  font-size: 32px;
  font-weight: bold;
  color: #333;
  margin-bottom: 8px;
}

.subtitle {
  display: block;
  font-size: 14px;
  color: #2ECC71;
}

.form {
  flex: 1;
}

.form-group {
  margin-bottom: 20px;
}

.form-group label {
  display: block;
  font-size: 14px;
  font-weight: bold;
  margin-bottom: 8px;
  color: #333;
}

.form-group input {
  width: 100%;
  padding: 12px;
  border: 1px solid #ddd;
  border-radius: 8px;
  font-size: 14px;
  box-sizing: border-box;
}

.input-with-btn {
  display: flex;
  gap: 8px;
}

.input-with-btn input {
  flex: 1;
}

.send-code-btn {
  padding: 12px 16px;
  background: rgba(46, 204, 113, 0.1);
  color: #2ECC71;
  border: none;
  border-radius: 8px;
  font-size: 12px;
  font-weight: bold;
  white-space: nowrap;
}

.login-btn {
  width: 100%;
  padding: 14px;
  background: #2ECC71;
  color: white;
  border-radius: 8px;
  font-size: 16px;
  font-weight: bold;
  margin-top: 24px;
}

.divider {
  text-align: center;
  margin: 32px 0;
  color: #999;
  font-size: 12px;
}

.social-buttons {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-bottom: 32px;
}

.social-btn {
  padding: 12px;
  border: 1px solid #ddd;
  background: white;
  border-radius: 8px;
  font-size: 14px;
  font-weight: bold;
}

.social-btn.whatsapp {
  color: #25D366;
  border-color: #25D366;
}

.social-btn.apple {
  background: #000;
  color: white;
  border-color: #000;
}

.footer {
  text-align: center;
  font-size: 12px;
  color: #999;
}

.footer-link {
  margin: 0 8px;
}